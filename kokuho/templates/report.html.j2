<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>🇯🇵 国宝チェックリスト レポート</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
<style>
  body { background: #f5f5f0; font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif; }
  .hero { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%); color: #fff; padding: 2.5rem 0 2rem; }
  .hero h1 { font-size: 2rem; font-weight: 700; letter-spacing: .05em; }
  .hero .subtitle { color: #aaa; font-size: 0.9rem; }
  .stat-card { background: #fff; border-radius: 12px; padding: 1.4rem 1.2rem; box-shadow: 0 2px 8px rgba(0,0,0,.08); text-align: center; }
  .stat-card .num { font-size: 2.2rem; font-weight: 700; color: #1a237e; }
  .stat-card .label { font-size: 0.8rem; color: #666; margin-top: 4px; }
  .section-title { font-size: 1.15rem; font-weight: 700; border-left: 4px solid #e53935; padding-left: .7rem; margin-bottom: 1rem; margin-top: .5rem; }
  .card-block { background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,.07); margin-bottom: 1.5rem; }
  .rate-bar-wrap { width: 100px; display: inline-block; }
  .rate-bar { height: 8px; border-radius: 4px; background: #e0e0e0; }
  .rate-bar-fill { height: 8px; border-radius: 4px; background: linear-gradient(90deg, #43a047, #1e88e5); }
  .badge-art  { background: #1565c0; color: #fff; font-size: .7rem; padding: 2px 7px; border-radius: 10px; }
  .badge-arch { background: #6a1b9a; color: #fff; font-size: .7rem; padding: 2px 7px; border-radius: 10px; }
  .table-sm td, .table-sm th { padding: .35rem .6rem; vertical-align: middle; }
  #filter-section input, #filter-section select { border-radius: 8px; }
  .no-treasure { color: #bbb; font-style: italic; }
  .pref-zero { color: #bbb; }
  .progress-ring { font-size: 2.8rem; font-weight: 800; color: #e53935; }
  .progress-sub { font-size: 1rem; color: #555; }
  footer { color: #999; font-size: .8rem; padding: 1.5rem 0; }
</style>
</head>
<body>

<!-- ヒーロー -->
<div class="hero">
  <div class="container">
    <h1>🇯🇵 国宝チェックリスト レポート</h1>
    <div class="subtitle">生成日時: {{ generated_at }}　文化資産の攻略台帳</div>
  </div>
</div>

<div class="container my-4">

  <!-- ① 全体達成率 -->
  <div class="card-block">
    <div class="section-title">① 全体達成率</div>
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="num">{{ overall.total }}</div>
          <div class="label">国宝総数</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="num" style="color:#43a047">{{ overall.viewed }}</div>
          <div class="label">観覧済み</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="num" style="color:#e53935">{{ overall.not_viewed | default(0) }}</div>
          <div class="label">未達</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="progress-ring">{{ "%.1f"|format(overall.rate * 100) }}%</div>
          <div class="progress-sub">達成率</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ② 都道府県別達成率 棒グラフ -->
  <div class="card-block">
    <div class="section-title">② 都道府県別達成率（所在県基準）</div>
    <div id="chart-pref"></div>

    <!-- テーブル -->
    <div class="mt-3">
      <table class="table table-sm table-hover" id="pref-table">
        <thead class="table-dark">
          <tr>
            <th>順位</th><th>都道府県</th><th class="text-end">総数</th>
            <th class="text-end">見た数</th><th class="text-end">未達数</th>
            <th>達成率</th>
          </tr>
        </thead>
        <tbody>
          {% set rank = namespace(v=0) %}
          {% for r in pref_stats %}
          <tr class="{{ 'pref-zero' if r.total == 0 else '' }}">
            <td>
              {% if r.total > 0 %}
                {% set rank.v = rank.v + 1 %}{{ rank.v }}
              {% else %}─{% endif %}
            </td>
            <td><strong>{{ r.prefecture }}</strong></td>
            <td class="text-end">{{ r.total }}</td>
            <td class="text-end" style="color:#43a047">{{ r.viewed }}</td>
            <td class="text-end" style="color:#e53935">{{ r.not_viewed | default(0) }}</td>
            <td>
              {% if r.total > 0 %}
              <div class="d-flex align-items-center gap-2">
                <div class="rate-bar-wrap">
                  <div class="rate-bar">
                    <div class="rate-bar-fill" style="width:{{ (r.rate * 100)|round(1) }}%"></div>
                  </div>
                </div>
                <span style="font-size:.85rem">{{ "%.1f"|format(r.rate * 100) }}%</span>
              </div>
              {% else %}
              <span class="pref-zero">国宝なし</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ③ カテゴリ別 / ④ 種別別 -->
  <div class="row g-3 mb-3">
    <div class="col-md-5">
      <div class="card-block h-100">
        <div class="section-title">③ カテゴリ別達成率</div>
        <div id="chart-cat"></div>
        <table class="table table-sm mt-2">
          <thead><tr><th>カテゴリ</th><th class="text-end">総数</th><th class="text-end">見た</th><th class="text-end">達成率</th></tr></thead>
          <tbody>
          {% for r in cat_stats %}
          <tr>
            <td>
              {% if r.category == 'art' %}<span class="badge-art">美術工芸品</span>
              {% else %}<span class="badge-arch">建造物</span>{% endif %}
            </td>
            <td class="text-end">{{ r.total }}</td>
            <td class="text-end" style="color:#43a047">{{ r.viewed }}</td>
            <td class="text-end"><strong>{{ "%.1f"|format(r.rate * 100) }}%</strong></td>
          </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    <div class="col-md-7">
      <div class="card-block h-100">
        <div class="section-title">④ 種別別達成率</div>
        <div id="chart-type"></div>
      </div>
    </div>
  </div>

  <!-- ⑤ 未達一覧 -->
  <div class="card-block">
    <div class="section-title">⑤ 未達一覧</div>

    <!-- フィルタ -->
    <div id="filter-section" class="row g-2 mb-3">
      <div class="col-sm-4">
        <select class="form-select form-select-sm" id="filter-pref">
          <option value="">── 都道府県（全て）──</option>
          {% for p in pref_options %}
          <option value="{{ p }}">{{ p }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="col-sm-3">
        <select class="form-select form-select-sm" id="filter-cat">
          <option value="">── カテゴリ（全て）──</option>
          <option value="art">美術工芸品</option>
          <option value="architecture">建造物</option>
        </select>
      </div>
      <div class="col-sm-5">
        <input type="text" class="form-control form-control-sm" id="filter-kw" placeholder="🔍 キーワード検索（名称・種別・所蔵者）">
      </div>
    </div>
    <div class="mb-2" id="filter-count" style="font-size:.85rem; color:#666;"></div>

    <div class="table-responsive">
      <table class="table table-sm table-hover" id="not-viewed-table">
        <thead class="table-secondary">
          <tr>
            <th>都道府県</th><th>カテゴリ</th><th>種別</th>
            <th>名称</th><th>所蔵者</th><th>施設</th>
          </tr>
        </thead>
        <tbody id="not-viewed-body">
          {% for r in not_viewed %}
          <tr
            data-pref="{{ r.prefecture }}"
            data-cat="{{ r.category }}"
            data-kw="{{ r.name }} {{ r.type or '' }} {{ r.holder or '' }} {{ r.facility or '' }}"
          >
            <td>{{ r.prefecture }}</td>
            <td>
              {% if r.category == 'art' %}<span class="badge-art">美工</span>
              {% else %}<span class="badge-arch">建造</span>{% endif %}
            </td>
            <td style="font-size:.82rem">{{ r.type or '' }}</td>
            <td><strong>{{ r.name }}</strong></td>
            <td style="font-size:.82rem">{{ r.holder or '' }}</td>
            <td style="font-size:.82rem">{{ r.facility or '' }}</td>
          </tr>
          {% else %}
          <tr><td colspan="6" class="text-center no-treasure">🎉 全て観覧済みです！</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

</div>

<footer class="container text-center">
  <p>🇯🇵 国宝チェックリストアプリ ─ 文化資産の攻略台帳</p>
</footer>

<!-- Plotly チャート描画 -->
<script>
(function() {
  var prefData = {{ chart_pref | safe }};
  Plotly.newPlot('chart-pref', prefData.data, prefData.layout, {responsive: true, displayModeBar: false});

  var catData = {{ chart_cat | safe }};
  Plotly.newPlot('chart-cat', catData.data, catData.layout, {responsive: true, displayModeBar: false});

  var typeData = {{ chart_type | safe }};
  Plotly.newPlot('chart-type', typeData.data, typeData.layout, {responsive: true, displayModeBar: false});
})();
</script>

<!-- 未達一覧 フィルタリング -->
<script>
(function() {
  var filterPref = document.getElementById('filter-pref');
  var filterCat  = document.getElementById('filter-cat');
  var filterKw   = document.getElementById('filter-kw');
  var countEl    = document.getElementById('filter-count');
  var tbody      = document.getElementById('not-viewed-body');

  function applyFilter() {
    var pref = filterPref.value;
    var cat  = filterCat.value;
    var kw   = filterKw.value.toLowerCase();
    var rows = tbody.querySelectorAll('tr[data-pref]');
    var visible = 0;
    rows.forEach(function(row) {
      var ok = true;
      if (pref && row.dataset.pref !== pref) ok = false;
      if (cat  && row.dataset.cat  !== cat)  ok = false;
      if (kw   && !row.dataset.kw.toLowerCase().includes(kw)) ok = false;
      row.style.display = ok ? '' : 'none';
      if (ok) visible++;
    });
    countEl.textContent = visible + ' 件表示中（未達 {{ not_viewed | length }} 件中）';
  }

  filterPref.addEventListener('change', applyFilter);
  filterCat.addEventListener('change', applyFilter);
  filterKw.addEventListener('input', applyFilter);
  applyFilter();
})();
</script>

</body>
</html>
